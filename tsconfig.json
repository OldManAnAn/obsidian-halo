{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "paths": {
      "src/*": ["./src/*"],
      "@halo-dev/api-client": ["./node_modules/@halo-dev/api-client/dist/index.d.ts"]
    },
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["DOM", "ES2022"]
  },
  "include": ["**/*.ts"]
}
